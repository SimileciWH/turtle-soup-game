# ============================================================
# 海龟汤环境变量
# 使用方法：复制本文件为 .env，填入真实值，不要提交 .env 到 Git
# ============================================================

# 数据库（PostgreSQL）
# 本地 Docker 快速启动：
#   docker run -d --name haiguitang \
#     -e POSTGRES_DB=haiguitang \
#     -e POSTGRES_USER=dev \
#     -e POSTGRES_PASSWORD=devpass \
#     -p 5432:5432 postgres:16
DATABASE_URL=postgresql://dev:devpass@localhost:5432/haiguitang

# JWT 签名密钥（64 位随机字符串）
# 生成命令：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=80c21b0eb4b7a1cc37f5f52f71fe23805965ddb833182bbb14720f064b59394fcb1cb7755b1f6c4ca7a2b1fe3f13b7f084ef9a92972d477544168e4722eb246c

# AI 接口（OpenAI 兼容格式，支持多家服务商）
# 七牛云示例：OPENAI_BASE_URL=https://api.qnaigc.com/v1
# MiniMax 示例：OPENAI_BASE_URL=https://api.minimaxi.chat/v1
OPENAI_BASE_URL=https://api.qnaigc.com/v1
OPENAI_API_KEY=请填入你的_API_Key
# 可用模型参考：deepseek-v3-0324 / glm-4.5-air / qwen3-32b
OPENAI_MODEL=deepseek-v3-0324

# 邮件服务（Resend，免费 3000 封/月）
# 注册：https://resend.com → Dashboard → API Keys → Create
RESEND_API_KEY=请填入你的_Resend_API_Key

# 服务配置
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ── 前端 Railway 环境变量（在 Railway 前端服务中设置）────────────────
# 本地开发不需要设置（Vite dev proxy 已处理）
# 生产部署时填写后端 Railway 服务的 URL
# VITE_API_BASE_URL=https://your-backend.railway.app/api/v1
