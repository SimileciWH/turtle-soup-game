# ── 数据库 ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/haiguitang

# ── 认证 ──────────────────────────────────────────────────
JWT_SECRET=your-random-64-char-string

# ── AI 接口（OpenAI 兼容） ─────────────────────────────────
OPENAI_BASE_URL=https://your-ai-provider/v1
OPENAI_API_KEY=your-api-key

# ── 邮件（Resend API，Railway 推荐方案） ──────────────────
# 1. 注册 resend.com，创建 API Key
# 2. 在 resend.com/domains 验证自己的域名（才能给任意邮箱发信）
# 3. 验证后将 RESEND_FROM 改为 noreply@yourdomain.com
RESEND_API_KEY=re_your-api-key
# 已验证域名后填写（未填则退回 onboarding@resend.dev 只能发给账号本人）
RESEND_FROM=noreply@yourdomain.com

# 方式 B：Gmail SMTP（本地开发用，云平台可能封端口）
# 1. 开启 Gmail 两步验证：myaccount.google.com/security
# 2. 生成应用专用密码：myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-specific-password

# ── 运行环境 ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
