{
  "name": "haiguitang-backend",
  "version": "1.0.0",
  "description": "AI 海龟汤游戏后端",
  "main": "dist/app.js",
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "scripts": {
    "dev": "dotenv -e ../.env -- ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:studio": "dotenv -e ../.env -- prisma studio",
    "db:seed": "dotenv -e ../.env -- ts-node prisma/seed.ts",
    "db:generate": "dotenv -e ../.env -- prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
